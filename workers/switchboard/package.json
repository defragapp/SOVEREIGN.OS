{
  "name": "sovereign-switchboard",
  "version": "0.5.0",
  "private": true,
  "description": "SOVEREIGN.OS — Cloudflare Worker AI switchboard (CF Workers AI edition — no Gemini key required)",
  "scripts": {
    "dev":              "wrangler dev",
    "deploy:staging":   "wrangler deploy --env staging",
    "deploy:production":"wrangler deploy --env production",
    "test":             "vitest run",
    "test:watch":       "vitest",
    "type-check":       "tsc --noEmit",
    "lint":             "eslint src --ext .ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "hono":                  "^4.6.3",
    "zod":                   "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.35",
    "@cloudflare/workers-types":       "^4.20241106.0",
    "typescript":                      "^5.6.3",
    "vitest":                          "^2.1.4",
    "wrangler":                        "^3.88.0"
  }
}
